{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run docs-api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/DocsApi.WebApi/bin/Debug/net10.0/DocsApi.WebApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5000"
      },
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": "Attach to docs-api",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
